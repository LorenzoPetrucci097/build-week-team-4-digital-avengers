# ─────────────────────────────────────────────────────────────
# keys.env - Template per le API keys
# ─────────────────────────────────────────────────────────────
#
# Copia questo file in:   ~/.config/claude-launcher/keys.env
# Poi imposta i permessi: chmod 600 ~/.config/claude-launcher/keys.env
#
# NON committare questo file su git con le chiavi vere dentro.
#
# ─────────────────────────────────────────────────────────────

# La tua chiave Anthropic ufficiale (dall'abbonamento).
# Ottienila da: https://console.anthropic.com/settings/keys
#
# NOTA: la chiamiamo *_REAL per non confonderla con la variabile
# ANTHROPIC_API_KEY che lo script imposta dinamicamente.
ANTHROPIC_API_KEY_REAL=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# La tua chiave OpenRouter.
# Ottienila da: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
